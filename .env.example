# Clerk — authentication provider. In development you can leave these blank:
# Next.js "keyless mode" auto-generates temporary dev keys on first `npm run dev`
# and shows a "Claim your application" banner to link them to your Clerk account.
# For production, create an app at https://dashboard.clerk.com and paste the keys.
# Never expose CLERK_SECRET_KEY in client code.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase — the database (cloud sync + store directory/catalog/reviews). Auth is
# handled by Clerk; wire the two together under Supabase → Authentication →
# Sign In / Providers → add Clerk (paste your Clerk domain). Create a project at
# https://supabase.com/dashboard and copy Project Settings → API values here.
# Without these the app runs in local-only mode.
NEXT_PUBLIC_SUPABASE_URL=https://zevcuwghteouwoschzuc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpldmN1d2dodGVvdXdvc2NoenVjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMzODk4MTksImV4cCI6MjA5ODk2NTgxOX0.qWMjdfS15DOSmR9wZHVzt5IOdibbzEv5S-_zS6DXFhk

# Public URL of the deployed site — used for Open Graph / share-link previews.
# Set this to your Railway domain (e.g. https://findtao-production.up.railway.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev/admin access — the account that signs in with this exact (verified) email
# is automatically granted the 'owner' role tag on first sign-in, unlocking the
# /dev panel. Checked server-side only (never shipped to the client). Leave blank
# to disable; change it to hand dev access to a different account.
DEV_EMAIL=

# Anthropic API key — powers the AI Advisor's size-chart reading (a single
# claude-haiku-4-5 vision call per chart, kept cheap on purpose). Get one at
# https://console.anthropic.com/settings/keys. Without this, the Advisor's
# chart-scan step returns a clear "not configured" error but the rest of the
# app is unaffected.
ANTHROPIC_API_KEY=

# JadeShip API key — powers the real product facts (marketplace title, price,
# weight, packed dimensions) shown when you open an album. The marketplaces
# themselves can't be read server-side (Weidian's item page returns a generic
# "商品详情" with no price, Taobao returns nothing) and the agents' own item APIs
# reject unsigned requests, so this is the supported way to get that data.
#
# Metered: $3 per 1000 lookups at the default field set (which includes weight).
# The app only looks an item up when a shopper opens its album — never across a
# grid — and caches each answer for 24h on the server (shared by everyone) and
# in the browser, so a given item costs roughly one lookup a day in total.
# Buy credit and create a key at https://www.jadeship.com/creators/api
# Without this, the product-facts panel simply doesn't render; nothing else changes.
JADESHIP_API_KEY=
